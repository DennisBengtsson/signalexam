\newlabel{fig:filtertyper}{{1.9}{71}{\texorpdfstring {\xpg@aux {\xpg@current@opts }{\languagename }}{}\ignorespaces De fyra grundläggande filtertyperna och deras överföringskurvor. Grönt = passband, rött = stoppband. $f_c$ = gränsfrekvens vid $-3\,\text {dB}$ (LP/HP). $f_1$, $f_2$ = bandgränser vid $-3\,\text {dB}$ (BP/BS), $f_0$ = centerfrekvens}{figure.1.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1.10}{\ignorespaces \xpg@aux {}{swedish}\ignorespaces Frekvensrespons för ett RC-lågpassfilter av första ordningen. Blå kurva = exakt svar $|H(f)| = 1/\!\sqrt  {1+(f/f_c)^2}$. Orange streckad = Bode-asymptot (0\,dB till $f_c$, sedan $-6$\,dB/oktav). Vid $2f_c$ är skillnaden $\approx 1$\,dB -- asymptoten är en god approximation men stämmer exakt bara långt ovanför $f_c$.}}{72}{figure.1.10}\protected@file@percent }
\newlabel{fig:rc-lp-bode}{{1.10}{72}{\texorpdfstring {\xpg@aux {\xpg@current@opts }{\languagename }}{}\ignorespaces Frekvensrespons för ett RC-lågpassfilter av första ordningen. Blå kurva = exakt svar $|H(f)| = 1/\!\sqrt {1+(f/f_c)^2}$. Orange streckad = Bode-asymptot (0\,dB till $f_c$, sedan $-6$\,dB/oktav). Vid $2f_c$ är skillnaden $\approx 1$\,dB -- asymptoten är en god approximation men stämmer exakt bara långt ovanför $f_c$}{figure.1.10}{}}
